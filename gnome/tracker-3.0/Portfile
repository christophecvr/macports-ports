PortSystem          1.0
PortGroup           compiler_blacklist_versions 1.0
PortGroup           meson 1.0

name                tracker-3.0
set my_name         tracker
version             3.0.2
revision            1
license             GPL-2+ LGPL-2.1+ BSD
set branch          [join [lrange [split ${version} .] 0 1] .]
description         Metadata database, indexer and search tool.
long_description    Tracker is an advanced framework for first class objects \
                    with associated metadata and tags. It provides a one stop \
                    solution for all metadata, tags, shared object databases, \
                    search tools and indexing.
                    
maintainers         {devans @dbevans} openmaintainer
categories          gnome
homepage            https://wiki.gnome.org/Projects/Tracker
master_sites        gnome:sources/${my_name}/${branch}/
use_xz              yes
distname            ${my_name}-${version}
dist_subdir         ${my_name}

checksums           rmd160 a91c2843392f4b45464e068f641e9bbac26db3b9 \
                            sha256 a60041cf47947ebbcfbba926d3b470bfdead21f3c12ce7aa93eaf1969a185c60

configure.compiler macports-clang-14

depends_build       port:pkgconfig \
                    port:intltool \
                    port:gtk-doc \
                    port:libtool


depends_lib         path:lib/pkgconfig/glib-2.0.pc:glib2 \
                    path:lib/pkgconfig/gobject-introspection-1.0.pc:gobject-introspection \
                    port:sqlite3 \
                    port:libgee \
                    port:libgrss \
                    path:bin/vala:vala \
                    port:libexif \
                    port:libiptcdata \
                    port:libmediaart \
                    port:libstemmer \
                    port:libunistring \
                    port:exempi \
                    port:taglib \
                    path:lib/pkgconfig/gdk-pixbuf-2.0.pc:gdk-pixbuf2 \
                    path:lib/pkgconfig/gtk+-3.0.pc:gtk3 \
                    port:libxml2 \
                    path:lib/pkgconfig/poppler.pc:poppler \
                    port:libgsf \
                    port:giflib \
                    port:libpng \
                    port:libvorbis \
                    port:flac \
                    port:totem-pl-parser \
                    port:json-glib \
                    path:lib/pkgconfig/icu-uc.pc:icu

configure.args  -Dman=false \
                -Ddocs=true  \
                -Dbash_completion=false \
                -Dsystemd_user_services=false \
                -Dtest_utils=true

patchfiles      pipe2-func.patch
 
 # blacklist compilers that do not support C11 (redefinition of typedef ‘TrackerSparqlBuilder’ at tracker-generated-no-checks.h:27)
compiler.blacklist  *gcc-3.* *gcc-4.* {clang < 300}
                    
# gobject-introspection uses g-ir-scanner, which uses $CC from env
if {${universal_possible} && [variant_isset universal]} {
    foreach arch ${configure.universal_archs} {
        lappend merger_build_env(${arch})  "CC=${configure.cc} -arch ${arch}"
        lappend merger_destroot_env(${arch})  "CC=${configure.cc} -arch ${arch}"
    }
} else {
    build.env-append       "CC=${configure.cc} ${configure.cc_archflags}"
    destroot.env-append    "CC=${configure.cc} ${configure.cc_archflags}"
}                    
                    
livecheck.type      gnome

